#include <WiFi.h>
#include <esp_now.h>

int number;

void receiveData(const esp_now_recv_info_t *info, const uint8_t *data, int len) {
  memcpy(&number, data, sizeof(number));

  Serial.print("Received: ");
  Serial.println(number);
}

void setup() {
  Serial.begin(115200);

  WiFi.mode(WIFI_STA);

  esp_now_init();

  esp_now_register_recv_cb(receiveData);
}

void loop() {
}
